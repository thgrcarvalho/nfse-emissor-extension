{
  "manifest_version": 3,
  "name": "NFS-e Nacional — Preenchimento (exportação)",
  "version": "0.3.1",
  "description": "Preenche o rascunho da NFS-e no Emissor Nacional para exportação de serviço (ME/EPP, Simples Nacional). Você revisa e emite.",
  "homepage_url": "https://github.com/thgrcarvalho/nfse-emissor-extension",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": ["https://*.nfse.gov.br/*", "https://olinda.bcb.gov.br/*"],
  "action": {
    "default_title": "Preencher NFS-e",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": { "default_path": "src/popup.html" },
  "sidebar_action": {
    "default_title": "Preencher NFS-e",
    "default_panel": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "src/sw.js", "scripts": ["src/sw.js"] },
  "browser_specific_settings": {
    "gecko": {
      "id": "nfse-emissor@trc.dev",
      "strict_min_version": "128.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.nfse.gov.br/EmissorNacional", "https://*.nfse.gov.br/EmissorNacional/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
