{
  "name": "nfse-emissor-extension",
  "version": "0.3.2",
  "private": true,
  "description": "Extensão MV3 que preenche o rascunho da NFS-e no Emissor Nacional (exportação de serviço).",
  "scripts": {
    "build": "node scripts/build.mjs",
    "lint": "eslint src scripts",
    "format": "prettier --write \"src/**/*.{js,html}\" \"scripts/**/*.mjs\" manifest.json",
    "format:check": "prettier --check \"src/**/*.{js,html}\" \"scripts/**/*.mjs\" manifest.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
